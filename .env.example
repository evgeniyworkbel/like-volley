POSTGRES_USER=string
POSTGRES_PASSWORD=string
POSTGRES_HOST=string
POSTGRES_DATABASE=string
POSTGRES_URL=postgres://$POSTGRES_USER:$POSTGRES_PASSWORD@$POSTGRES_HOST/$POSTGRES_DATABASE
PAYLOAD_SECRET=unique string
IS_CUSTOM_VPS=true/false

YC_S3_BUCKET=your-bucket-name
YC_S3_ACCESS_KEY_ID=your-static-access-key-id
YC_S3_SECRET_ACCESS_KEY=your-static-secret-access-key
# Optional per-object ACL. Omit unless the service account can set object ACLs.
# For public media, configure bucket-level public read in Yandex Cloud instead.
# YC_S3_ACL=public-read

NEXT_PUBLIC_YANDEX_METRIKA_COUNTER_ID=number